+++ b/dlls/win32u/freetype.c
@@ -69,6 +69,7 @@
 #include "ntgdi_private.h"
 #include "wine/debug.h"
 #include "wine/list.h"
+#include "wine/rbtree.h"
 
 #ifdef SONAME_LIBFREETYPE
 
@@ -160,6 +161,45 @@ MAKE_FUNCPTR(FcStrSetMember);
 #endif
 #endif /* SONAME_LIBFONTCONFIG */
 
+/* Font file deduplication: track loaded fonts by (device, inode) to avoid
+   parsing the same font file twice (e.g., from C:\windows\fonts\ and fontconfig) */
+
+struct loaded_font_file
+{
+    struct wine_rb_entry   entry;
+    dev_t                  dev;
+    ino_t                  ino;
+};
+
+static int loaded_font_compare( const void *key, const struct wine_rb_entry *entry )
+{
+    const struct loaded_font_file *a = key;
+    const struct loaded_font_file *b = WINE_RB_ENTRY_VALUE( entry, const struct loaded_font_file, entry );
+    if (a->dev < b->dev) return -1;
+    if (a->dev > b->dev) return 1;
+    if (a->ino < b->ino) return -1;
+    if (a->ino > b->ino) return 1;
+    return 0;
+}
+
+static struct wine_rb_tree loaded_fonts = { loaded_font_compare };
+
+static BOOL is_font_already_loaded( dev_t dev, ino_t ino )
+{
+    struct loaded_font_file key;
+    key.dev = dev;
+    key.ino = ino;
+    return wine_rb_get( &loaded_fonts, &key ) != NULL;
+}
+
+static void mark_font_loaded( dev_t dev, ino_t ino )
+{
+    struct loaded_font_file *loaded = malloc( sizeof(*loaded) );
+    loaded->dev = dev;
+    loaded->ino = ino;
+    wine_rb_put( &loaded_fonts, loaded, &loaded->entry );
+}
+
 #undef MAKE_FUNCPTR
 
 #ifndef FT_MAKE_TAG
@@ -1060,6 +1100,16 @@ static INT AddFontToList(const WCHAR *dos_name, const char *unix_name, void *fon
     /* we always load external fonts from files - otherwise we would get a crash in update_reg_entries */
     assert(unix_name || !(flags & ADDFONT_EXTERNAL_FONT));
 
+    if (unix_name)
+    {
+        struct stat st;
+        if (!stat( unix_name, &st ))
+        {
+            if (is_font_already_loaded( st.st_dev, st.st_ino )) return 0;
+            mark_font_loaded( st.st_dev, st.st_ino );
+        }
+    }
+
     if (!dos_name && unix_name && !ntdll_get_dos_file_name( unix_name, &filename, FILE_OPEN ))
         dos_name = filename;
 
@@ -1201,6 +1251,13 @@ static void fontconfig_add_font( FcPattern *pattern, UINT flags )
     if (pFcPatternGetString( pattern, FC_FILE, 0, (FcChar8 **)&unix_name ) != FcResultMatch)
         return;
 
+    /* skip fonts already loaded by the filesystem scan */
+    {
+        struct stat st;
+        if (!stat( unix_name, &st ) && is_font_already_loaded( st.st_dev, st.st_ino )) return;
+        mark_font_loaded( st.st_dev, st.st_ino );
+    }
+
     if (pFcPatternGetBool( pattern, FC_SCALABLE, 0, &scalable ) != FcResultMatch)
         scalable = FALSE;
 
@@ -1348,7 +1405,7 @@ static void load_fontconfig_fonts( void )
