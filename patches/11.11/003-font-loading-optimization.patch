 #undef MAKE_FUNCPTR
 
+struct loaded_font_file
+{
+    struct wine_rb_entry   entry;
+    dev_t                  dev;
+    ino_t                  ino;
+};
+
+static int loaded_font_compare( const void *key, const struct wine_rb_entry *entry )
+{
+    const struct loaded_font_file *a = key;
+    const struct loaded_font_file *b = WINE_RB_ENTRY_VALUE( entry, const struct loaded_font_file, entry );
+    if (a->dev < b->dev) return -1;
+    if (a->dev > b->dev) return 1;
+    if (a->ino < b->ino) return -1;
+    if (a->ino > b->ino) return 1;
+    return 0;
+}
+
+static struct wine_rb_tree loaded_fonts = { loaded_font_compare };
+
+static BOOL is_font_already_loaded( dev_t dev, ino_t ino )
+{
+    struct loaded_font_file key;
+    key.dev = dev;
+    key.ino = ino;
+    return wine_rb_get( &loaded_fonts, &key ) != NULL;
+}
+
+static void mark_font_loaded( dev_t dev, ino_t ino )
+{
+    struct loaded_font_file *loaded = malloc( sizeof(*loaded) );
+    loaded->dev = dev;
+    loaded->ino = ino;
+    wine_rb_put( &loaded_fonts, loaded, &loaded->entry );
+}
