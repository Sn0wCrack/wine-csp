+static HRESULT create_encoder_transform(IMFMediaType *input_type, IMFMediaType *output_type, 
+        IMFTransform **encoder)
+{
+    GUID major_type, subtype;
+    MFT_REGISTER_TYPE_INFO output_info;
+    IMFActivate **activates = NULL;
+    UINT32 count = 0;
+    HRESULT hr;
+
+    *encoder = NULL;
+
+    hr = IMFMediaType_GetGUID(output_type, &MF_MT_MAJOR_TYPE, &major_type);
+    if (FAILED(hr)) return hr;
+
+    hr = IMFMediaType_GetGUID(output_type, &MF_MT_SUBTYPE, &subtype);
+    if (FAILED(hr)) return hr;
+
+    output_info.guidMajorType = major_type;
+    output_info.guidSubtype = subtype;
+
+    hr = MFTEnumEx(MFT_CATEGORY_VIDEO_ENCODER, MFT_ENUM_FLAG_ALL,
+                   NULL, &output_info, &activates, &count);
+
+    if (FAILED(hr) || count == 0)
+    {
+        if (activates) CoTaskMemFree(activates);
+        return hr == S_OK ? MF_E_TOPO_CODEC_NOT_FOUND : hr;
+    }
+
+    for (UINT32 i = 0; i < count; i++)
+    {
+        IMFTransform *transform = NULL;
+
+        hr = IMFActivate_ActivateObject(activates[i], &IID_IMFTransform, (void **)&transform);
+        if (FAILED(hr))
+            continue;
+
+        hr = IMFTransform_SetOutputType(transform, 0, output_type, 0);
+        if (FAILED(hr))
+        {
+            IMFTransform_Release(transform);
+            continue;
+        }
+
+        hr = IMFTransform_SetInputType(transform, 0, input_type, 0);
+        if (FAILED(hr))
+        {
+            IMFTransform_Release(transform);
+            continue;
+        }
+
+        *encoder = transform;
+        break;
+    }
+
+    for (UINT32 i = 0; i < count; i++)
+        IMFActivate_Release(activates[i]);
+    CoTaskMemFree(activates);
+
+    if (!*encoder)
+        return MF_E_TOPO_CODEC_NOT_FOUND;
+
+    return S_OK;
+}
