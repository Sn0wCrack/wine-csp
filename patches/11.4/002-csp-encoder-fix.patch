+                    IMFSample *encoded_sample;
+                    struct pending_item *item;
+                    DWORD status;
+
+                    if (FAILED(IMFTransform_GetOutputStreamInfo(stream->encoder, 0, &info)))
+                        break;
+
+                    if (FAILED(MFCreateSample(&encoded_sample)))
+                        break;
+
+                    if (FAILED(MFCreateMemoryBuffer(info.cbSize ? info.cbSize : 1024 * 1024, &buffer)))
+                    {
