+
+    /* grid-fit to 64-unit (1 pixel) boundaries in 26.6 fixed-point.
+     * xMin/yMin round toward negative infinity (expanding the box outward on
+     * left/bottom edges), xMax/yMax round up (expanding on right/top edges). */
+    bbox.xMin = bbox.xMin & -64;
+    bbox.xMax = (bbox.xMax + 63) & -64;
+    bbox.yMin = bbox.yMin & -64;
+    bbox.yMax = (bbox.yMax + 63) & -64;
+
+    /* convert from 26.6 fixed-point to integer pixels */
+    bbox.xMin >>= 6;
+    bbox.xMax >>= 6;
+    bbox.yMin >>= 6;
+    bbox.yMax >>= 6;
+
     pFT_Done_Glyph(glyph);
     pFT_Done_Size(size);
 
